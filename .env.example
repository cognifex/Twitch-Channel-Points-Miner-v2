# Twitch Channel Points Miner v2
# Docker Compose: alle verfügbaren .env-Flags
#
# Nutzung:
# 1) Datei nach .env kopieren
# 2) Gewünschte Flags aktivieren (Kommentarzeichen entfernen)
# 3) Werte anpassen

# --------------------
# Miner-Container
# --------------------
# CONTAINER_NAME=twitch-channel-points-miner
# TERM=xterm-256color
# TZ=UTC

# --------------------
# Mounts / Pfade
# --------------------
# ANALYTICS_DIR=./analytics
# COOKIES_DIR=./cookies
# LOGS_DIR=./logs
# RUN_FILE=./run.py

# --------------------
# Ports
# --------------------
# ANALYTICS_PORT=5000

# --------------------
# WebUI-Container
# --------------------
# WEBUI_CONTAINER_NAME=twitch-channel-points-webui
# WEBUI_PORT=8080
