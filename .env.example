# Twitch Channel Points Miner v2
# Docker Compose: alle verfügbaren .env-Flags
#
# Nutzung:
# 1) Datei nach .env kopieren
# 2) Gewünschte Flags aktivieren (Kommentarzeichen entfernen)
# 3) Werte anpassen

# --------------------
# Miner-Container
# --------------------
# CONTAINER_NAME=twitch-channel-points-miner
# TERM=xterm-256color
# TZ=UTC

# Keep miner container alive when login fails (lets WebUI stay usable for recovery)
# TCPM_KEEP_ALIVE_ON_LOGIN_FAILURE=1

# --------------------
# Mounts / Pfade
# --------------------
# ANALYTICS_DIR=./analytics
# COOKIES_DIR=./cookies
# LOGS_DIR=./logs
# RUN_FILE=./run.py

# Optional fallback: use a Twitch auth token directly when no cookies/<username>.pkl exists
# TWITCH_AUTH_TOKEN=

# --------------------
# Ports
# --------------------
# ANALYTICS_PORT=5000

# --------------------
# WebUI-Container
# --------------------
# WEBUI_CONTAINER_NAME=twitch-channel-points-webui
# WEBUI_PORT=8080
