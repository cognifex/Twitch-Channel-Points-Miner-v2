# Docker image to run
MINER_IMAGE=tkdalex/twitch-channel-points-miner-v2

# Compose/container metadata
CONTAINER_NAME=twitch-channel-points-miner
TZ=UTC
TERM=xterm-256color

# Host paths (relative to this repo by default)
ANALYTICS_DIR=./analytics
COOKIES_DIR=./cookies
LOGS_DIR=./logs
RUN_FILE=./run.py

# Exposed analytics dashboard port
ANALYTICS_PORT=5000
